<launch>
    <!-- <include file="$(find livox_ros_driver2)/launch_ROS1/msg_MID360.launch"/> -->
    <!-- <include file="$(find ranger_bringup)/launch/ranger_mini_v2.launch"/> -->
    <arg name="sim" default="true"/>
    <arg name="home" default="/home/xu"/>
    <arg name="rviz" default="true" />

    <param name="use_sim_time" value="$(arg sim)" />
    <param name="home_dir" value="$(arg home)"/>

    <node pkg="tf2_ros" type="static_transform_publisher" name="map_to_camera_init" args="0 0 0 0 0 0 map camera_init" />
    <node pkg="tf2_ros" type="static_transform_publisher" name="aft_mapped_to_baselink" args="0 0 0 0 0 0 aft_mapped baselink" />
    
    <rosparam file="$(find nav_launch)/params/plugins.yaml" command="load"/>

    <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen" clear_params="true">
        <rosparam file="$(find nav_launch)/params/move_base_params.yaml" command="load"/>
        <rosparam file="$(find nav_launch)/params/costmap_common_params.yaml" command="load" ns="global_costmap" />
        <rosparam file="$(find nav_launch)/params/costmap_common_params.yaml" command="load" ns="local_costmap" />
        <rosparam file="$(find nav_launch)/params/local_costmap_params.yaml" command="load" />
        <rosparam file="$(find nav_launch)/params/global_costmap_params.yaml" command="load" />
        
        <!-- Hector Exploration Parameters -->
        <rosparam file="$(find nav_launch)/params/hector_exploration_params.yaml" command="load" />
        
        <!-- Teb Local Planner Parameters -->
        <rosparam file="$(find nav_launch)/params/teb_local_planner_params.yaml" command="load" />
        
        <!-- Set Base Global/Local Planners -->
        <param name="base_global_planner" value="hector_exploration_planner/HectorExplorationBaseGlobalPlannerPlugin" />
        <param name="base_local_planner" value="teb_local_planner/TebLocalPlannerROS" />
    </node>
    
    <include file="$(find octomap_server)/launch/octomap_mapping.launch" />

    <!-- Hector Exploration Hybrid Trigger Node -->
    <node pkg="nav_launch" type="plan_explore_trigger.py" name="plan_explore_trigger_node" output="screen" />

    <group if="$(arg rviz)">
        <node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz" args="-d $(find nav_launch)/rviz_cfg/navigation.rviz" />	
    </group>
</launch>
