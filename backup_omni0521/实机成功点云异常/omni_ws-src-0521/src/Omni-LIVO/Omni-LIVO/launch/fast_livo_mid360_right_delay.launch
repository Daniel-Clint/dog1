<launch>
    <arg name="rviz" default="true" />

    <rosparam command="load" file="$(find fast_livo)/config/mid360_multi_cam_right_delay.yaml" />

    <node pkg="fast_livo" type="fastlivo_mapping" name="laserMapping" output="screen" >
        <param name="visual_en" type="bool" value="true" />

        <param name="cam_num" type="int" value="2" />
        <rosparam command="load" file="$(find fast_livo)/config/camera_intrinsics.yaml" />
        
    </node>
    
    <group if="$(arg rviz)">
        <node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz" args="-d $(find fast_livo)/rviz_cfg/mid360.rviz" />
    </group>

</launch>
